{
  "name": "@react-workshop/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": ["dist", "src/styles.css"],
  "scripts": {
    "build": "tsup src/button/button.tsx src/card/card.tsx src/input/input.tsx --format esm --dts --external react --external react/jsx-runtime --clean",
    "dev": "tsup src/button/button.tsx src/card/card.tsx src/input/input.tsx --format esm --dts --external react --external react/jsx-runtime --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "pnpm typecheck"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@react-workshop/eslint-config": "workspace:*",
    "@react-workshop/tsconfig": "workspace:*",
    "@storybook/addon-docs": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "storybook": "catalog:",
    "tailwindcss": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
