{
  "name": "@react-workshop/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": ["dist", "src/styles.css"],
  "scripts": {
    "build": "tsup src/button/button.tsx src/card/card.tsx src/input/input.tsx --format esm --dts --external react --external react/jsx-runtime --clean",
    "dev": "tsup src/button/button.tsx src/card/card.tsx src/input/input.tsx --format esm --dts --external react --external react/jsx-runtime --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "pnpm typecheck"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@react-workshop/eslint-config": "workspace:*",
    "@react-workshop/tsconfig": "workspace:*",
    "@storybook/addon-docs": "^9.0.0",
    "@storybook/react-vite": "^9.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.30.0",
    "storybook": "^9.0.0",
    "tailwindcss": "^4.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
