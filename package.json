{
  "name": "react-work-shop-2026",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.3",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "storybook": "pnpm --filter @react-workshop/ui storybook",
    "test": "turbo test",
    "figma:assets": "node scripts/download-figma-assets.mjs",
    "figma:regroup": "node scripts/regroup-figma-assets.mjs",
    "mock:generate": "node scripts/generate-dummyjson-mocks.mjs"
  },
  "devDependencies": {
    "@react-workshop/eslint-config": "workspace:*",
    "eslint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
